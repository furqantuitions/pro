# Base URL of the Cloud PDF Service API (no trailing slash needed)
VITE_API_BASE_URL=https://api.example.com

# Shared API key. Because this is a static front end, this key ships in the
# JS bundle and is visible in dev tools. Fine for a demo; for production,
# put a small server-side proxy in front of it instead.
VITE_API_KEY=your-api-key-here

# --- Print Shop Locator service ---
# Separate backend from the Cloud PDF Service above — different base URL
# (and optional key), kept independent on purpose.
VITE_KIOSKS_API_BASE_URL=https://kiosks.example.com
VITE_KIOSKS_API_KEY=
